{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "serialsales",
  "main": "@tanstack/react-start/server-entry",
  "compatibility_date": "2026-06-18",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": false,
  "routes": [
    {
      "pattern": "serialsales.nicolaischmid.com",
      "custom_domain": true
    }
  ],
  "r2_buckets": [
    {
      "binding": "TRANSCRIPTS",
      "bucket_name": "serialsales-transcripts"
    }
  ],
  "observability": {
    "enabled": true
  }
}
